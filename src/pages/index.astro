    <script>
        // ── Page-load fade-in ─────────────────────────────────
        document.documentElement.style.opacity = '0';
        document.documentElement.style.transition = 'opacity 0.45s ease';
        window.addEventListener('load', () => { document.documentElement.style.opacity = '1'; });

        // ── Typed text effect on hero ─────────────────────────
        const typedEl = document.getElementById('typed-word');
        const cursor  = document.getElementById('typed-cursor');
        const words   = ['Maintenance Toll Road',];
        let wi = 0, ci = 0, deleting = false;
        const SPEED_TYPE = 80, SPEED_DEL = 45, PAUSE = 2200;
        function typeLoop() {
            if (!typedEl) return;
            const word = words[wi];
            if (!deleting) {
                typedEl.textContent = word.slice(0, ++ci);
                if (ci === word.length) { deleting = true; setTimeout(typeLoop, PAUSE); return; }
            } else {
                typedEl.textContent = word.slice(0, --ci);
                if (ci === 0) { deleting = false; wi = (wi + 1) % words.length; }
            }
            setTimeout(typeLoop, deleting ? SPEED_DEL : SPEED_TYPE);
        }
        // Start after AOS intro delay
        setTimeout(typeLoop, 1800);

        // ── Hero Slider ───────────────────────────────────────
        const slides = document.querySelectorAll('.hero-slide');
        const dots = document.querySelectorAll('.hero-dot');
        const prevBtn = document.getElementById('hero-prev');
        const nextBtn = document.getElementById('hero-next');
        let currentSlide = 0;
        let slideInterval: number;

        function showSlide(index: number) {
            slides.forEach((slide, i) => {
                if (i === index) {
                    slide.classList.remove('absolute', 'inset-0', 'opacity-0', 'pointer-events-none', 'z-0');
                    slide.classList.add('relative', 'opacity-100', 'z-10');
                } else {
                    slide.classList.remove('relative', 'opacity-100', 'z-10');
                    slide.classList.add('absolute', 'inset-0', 'opacity-0', 'pointer-events-none', 'z-0');
                }
            });

            dots.forEach((dot, i) => {
                if (i === index) {
                    dot.classList.remove('bg-white/30');
                    dot.classList.add('bg-yellow-500');
                } else {
                    dot.classList.remove('bg-yellow-500');
                    dot.classList.add('bg-white/30');
                }
            });

            currentSlide = index;
        }

        function nextSlide() {
            const next = (currentSlide + 1) % slides.length;
            showSlide(next);
        }

        function prevSlide() {
            const prev = (currentSlide - 1 + slides.length) % slides.length;
            showSlide(prev);
        }

        function startAutoplay() {
            stopAutoplay();
            slideInterval = setInterval(nextSlide, 6000) as any;
        }

        function stopAutoplay() {
            if (slideInterval) clearInterval(slideInterval);
        }

        prevBtn?.addEventListener('click', () => {
            prevSlide();
            startAutoplay();
        });

        nextBtn?.addEventListener('click', () => {
            nextSlide();
            startAutoplay();
        });

        dots.forEach((dot, i) => {
            dot.addEventListener('click', () => {
                showSlide(i);
                startAutoplay();
            });
        });

        if (slides.length > 0) {
            startAutoplay();
        }

        // ── Counter animation (scroll-triggered) ─────────────
        function animateCounter(el: HTMLElement, target: number, duration: number, suffix = '+') {
            const obs = new IntersectionObserver(entries => {
                entries.forEach(e => {
                    if (!e.isIntersecting) return;
                    const start = performance.now();
                    const tick = (now: number) => {
                        const p = Math.min((now - start) / duration, 1);
                        const ease = 1 - Math.pow(1 - p, 3);
                        el.textContent = Math.round(ease * target) + suffix;
                        if (p < 1) requestAnimationFrame(tick);
                    };
                    requestAnimationFrame(tick);
                    obs.unobserve(el);
                });
            }, { threshold: 0.5 });
            obs.observe(el);
        }
        const counterLayanan = document.getElementById('counter-layanan');
        if (counterLayanan) animateCounter(counterLayanan as HTMLElement, 9, 1400, '+');

        const counterPengalaman = document.getElementById('counter-pengalaman');
        if (counterPengalaman) animateCounter(counterPengalaman as HTMLElement, 5, 1400, '+');

        const counterProyek = document.getElementById('counter-proyek');
        if (counterProyek) animateCounter(counterProyek as HTMLElement, 4, 1400, '+');

        // ── Mobile menu slide-down animation ─────────────────
        const mobileMenu = document.getElementById('mobile-menu');
        const origToggle = mobileMenu?.classList.toggle.bind(mobileMenu.classList);
        const menuObserver = new MutationObserver(() => {
            if (mobileMenu && !mobileMenu.classList.contains('hidden')) {
                mobileMenu.classList.add('mobile-menu-open');
            }
        });
        if (mobileMenu) menuObserver.observe(mobileMenu, { attributes: true, attributeFilter: ['class'] });

        // ── Parallax subtle on hero orbs ─────────────────────
        const orbs = document.querySelectorAll<HTMLElement>('.hero-orb');
        window.addEventListener('scroll', () => {
            const y = window.scrollY;
            orbs.forEach((orb, i) => {
                orb.style.transform = `translateY(${y * (i % 2 === 0 ? 0.08 : -0.06)}px)`;
            });
        }, { passive: true });
        // ── Scroll-to-top button ──────────────────────────────────────────────
        const scrollBtn = document.getElementById('scroll-top-btn');
        window.addEventListener('scroll', () => {
            if (window.scrollY > 400) scrollBtn?.classList.add('visible');
            else scrollBtn?.classList.remove('visible');
        }, { passive: true });
        scrollBtn?.addEventListener('click', () => {
            window.scrollTo({ top: 0, behavior: 'smooth' });
        });

        // ── Sound toggle on hero click ────────────────────────
        const heroVideo = document.getElementById('hero-video') as HTMLVideoElement;
        const soundIcon = document.getElementById('sound-icon');
        function toggleSound() {
            if (!heroVideo) return;
            heroVideo.muted = !heroVideo.muted;
            if (soundIcon) soundIcon.textContent = heroVideo.muted ? '🔇' : '🔊';
        }
        // Clicking anywhere on hero section to unmute
        document.getElementById('beranda')?.addEventListener('click', (e) => {
            const target = e.target as HTMLElement;
            if (target.closest('#sound-toggle')) return;
            if (heroVideo && heroVideo.muted) {
                heroVideo.muted = false;
                if (soundIcon) soundIcon.textContent = '🔊';
            }
        });
        // Mute again when user scrolls away from hero
        const beranda = document.getElementById('beranda');
        const muteObserver = new IntersectionObserver((entries) => {
            entries.forEach(e => {
                if (!e.isIntersecting && heroVideo && !heroVideo.muted) {
                    heroVideo.muted = true;
                    if (soundIcon) soundIcon.textContent = '🔇';
                }
            });
        }, { threshold: 0.1 });
        if (beranda) muteObserver.observe(beranda);
        (window as any).toggleSound = toggleSound;
    </script>
