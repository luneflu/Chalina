      "/galeri/minggu 15 feb/minggu_2.webp",
      "/galeri/minggu 15 feb/minggu_3.webp",
      "/galeri/minggu 15 feb/minggu_4.webp",
      "/galeri/minggu 15 feb/minggu_5.webp",
      "/galeri/minggu 15 feb/minggu_6.webp",
      "/galeri/minggu 15 feb/minggu_7.webp",
      "/galeri/minggu 15 feb/minggu_8.webp",
      "/galeri/minggu 15 feb/minggu_9.webp",
      "/galeri/minggu 15 feb/minggu_10.webp",
      "/galeri/minggu 15 feb/minggu_11.webp",
      "/galeri/minggu 15 feb/minggu_12.webp",
      "/galeri/minggu 15 feb/minggu_13.webp",
      "/galeri/minggu 15 feb/minggu_14.webp",
      "/galeri/minggu 15 feb/minggu_15.webp"
    ]
  },
  {
    title: "Flagman & Traffic Control",
    subtitle: "TRAFFIC SAFETY",
    images: [
      "/galeri/flagman 2.png",
      "/galeri/flagman 3.png",
      "/galeri/flagman 4.png",
      "/galeri/flagman 5.png",
      "/galeri/flagman.png"
    ]
  },
  {
    title: "Armada & Logistik",
    subtitle: "LOGISTICS & FLEET",
    images: [
      "/galeri/truk 1.png",
      "/galeri/truk 2.png",
      "/galeri/truk 3-4.png",
      "/galeri/truk 5.png",
      "/galeri/truk 6.png",
      "/galeri/truk 7.png",
      "/galeri/truk 8.png"
    ]
  },
  {
    title: "Peralatan & Kompresor",
    subtitle: "EQUIPMENT READINESS",
    images: [
      "/galeri/kompresor.webp",
      "/galeri/peralatan_1.webp",
      "/galeri/peralatan_2.webp",
      "/galeri/peralatan_3.webp",
      "/galeri/peralatan_4.webp",
      "/galeri/peralatan_5.webp"
    ]
  },
  {
    title: "Kesiapan Personel & Briefing",
    subtitle: "OPERATIONAL READINESS",
    images: [
      "/images/toolbox-meeting.webp",
      "/images/new-toolbox-meeting.webp",
      "/images/labor-supply.webp",
      "/galeri/personel_1.webp",
      "/galeri/personel_2.webp",
      "/galeri/personel_3.webp",
      "/galeri/personel_4.webp",
      "/galeri/personel_5.webp",
