---
import Icon from '../components/Icon.astro';
import Layout from '../layouts/Layout.astro';
import AppNavigation from '../components/AppNavigation.astro';
import ServiceCard from '../components/ServiceCard.astro';
import AdvantageCard from '../components/AdvantageCard.astro';
import GalleryCarousel from '../components/GalleryCarousel.astro';

const galleryCategories = [
  {
    title: "Perawatan Jalan Tol ",
    subtitle: "ROAD MAINTENANCE",
    images: [
      "/galeri/16 feb L2-L3/l2_l3_1.webp",
      "/galeri/16 feb L2-L3/l2_l3_2.webp",
      "/galeri/16 feb L2-L3/l2_l3_3.webp",
      "/galeri/16 feb L2-L3/l2_l3_4.webp",
      "/galeri/16 feb L2-L3/l2_l3_5.webp",
      "/galeri/16 feb L2-L3/l2_l3_6.webp",
      "/galeri/16 feb L2-L3/l2_l3_7.webp",
      "/galeri/16 feb L2-L3/l2_l3_8.webp",
      "/galeri/16 feb L2-L3/l2_l3_9.webp",
      "/galeri/16 feb L2-L3/l2_l3_10.webp",
      "/galeri/16 feb L2-L3/l2_l3_11.webp",
      "/galeri/16 feb L2-L3/l2_l3_12.webp",
      "/galeri/16 feb L2-L3/l2_l3_13.webp",
      "/galeri/16 feb L2-L3/l2_l3_14.webp",
      "/galeri/16 feb L2-L3/l2_l3_15.webp"
    ]
  },
  {
    title: "Perawatan drainase & gorong-gorong",
    subtitle: "DRAINAGE MAINTENANCE",
    images: [
      "/images/drainage-system-cleaning.webp",
        "/images/drainage-maintenance-1.webp",
        "/images/drainage-maintenance-2.webp",
      
    ]
  },
  {
    title: "Perawatan Taman",
    subtitle: "Garden Maintenance",
    images: [
      "/images/garden-maintenance.webp",
      "/images/garden-maintenance-2.webp",
      "/images/garden-maintenance-4.webp",
    ]
  },
  {
    title: "Pembersihan rambu & marka jalan",
    subtitle: "TRAFFIC SIGN CLEANING",
    images: [
      "/images/traffic-sign-cleaning.webp",
      "/galeri/personel_3.webp",
      "/galeri/personel_4.webp",
      "/galeri/personel_7.webp",
      "/galeri/personel_11.webp",
      "/galeri/personel_9.webp",
      "/galeri/personel_10.webp"
    ]
  },
  {
    title: "Pembersihan jalan ",
    subtitle: "ROAD CLEANING",
    images: [
      "/galeri/personel_5.webp",
      "/images/personel_12.webp",
      "/images/path-cleaning.webp",
      "/images/trash-cleaning-1.webp",
      "/images/traffic-cleaning-service.webp",
      "/galeri/cleaning_paravet_4.webp",
      "/images/concrete-barrier.webp"
    ]
  },
  {
    title: "Kesiapan Personel & Briefing",
    subtitle: "OPERATIONAL READINESS",
    images: [
      "/images/toolbox-meeting.webp",
      "/images/new-toolbox-meeting.webp",
      "/images/labor-supply.webp",
      "/galeri/personel_1.webp",
      //"/galeri/personel_2.webp",
      "/galeri/personel_6.webp",
    ]
  },
  {
    title: "outsourcing tenaga kerja",
    subtitle: "LABOR OUTSOURCING",
    images: [
      "/images/outsourcing.webp",
     
      
    ]
  },
];
---

<Layout title="PT Cahaya Lintang Abadi">
    <!-- Navigation -->
    <AppNavigation />

    <!-- Floating WhatsApp Button -->
    <a href="https://wa.me/6282320813439" target="_blank" 
       class="fixed bottom-6 right-6 z-50 bg-green-500 rounded-full p-4 shadow-lg hover:bg-green-600 transition-all duration-300 hover:scale-110 flex items-center justify-center group"
       aria-label="Hubungi via WhatsApp">
        <Icon icon="fa-brands fa-whatsapp" class="text-white text-3xl" />
        <span class="absolute right-full mr-3 bg-gray-900 text-white text-sm font-sans px-3 py-2 rounded-lg opacity-0 group-hover:opacity-100 transition-opacity duration-300 whitespace-nowrap pointer-events-none">
            Hubungi Kami
        </span>
    </a>

    <!-- Hero Section -->
    <main id="beranda" class="w-full flex items-center justify-center p-4 md:p-8 min-h-screen pt-24 pb-24 relative overflow-hidden">
        <div class="absolute inset-0 z-0">
            <div class="absolute inset-0 bg-zinc-900/50 mix-blend-multiply z-10"></div>
            <video 
                id="hero-video"
                autoplay 
                loop 
                muted
                playsinline 
                 class="w-full h-full object-cover opacity-90"
            >
                <source src="/video/calina_home.mp4" type="video/mp4" />
            </video>
            <!-- Sound toggle button -->
            <button id="sound-toggle" onclick="toggleSound()" class="absolute bottom-20 right-6 z-20 bg-black/50 border border-white/30 text-white rounded-full w-10 h-10 flex items-center justify-center hover:bg-black/70 transition-all" title="Toggle suara">
                <span id="sound-icon">🔇</span>
            </button>
            <!-- Animated ambient orbs -->
            <div class="hero-orb absolute top-1/4 left-1/4 w-96 h-96 rounded-full bg-yellow-500/5 blur-3xl animate-float" style="animation-duration:7s"></div>
            <div class="hero-orb absolute bottom-1/4 right-1/4 w-80 h-80 rounded-full bg-yellow-400/4 blur-3xl animate-float" style="animation-duration:9s;animation-delay:2s"></div>
        </div>

        <div class="max-w-6xl w-full relative z-10">
            <!-- Slides Container -->
            <div class="relative w-full">
                <!-- Slide 1 -->
                <div class="hero-slide w-full flex flex-col lg:flex-row items-center justify-between gap-12 transition-all duration-700 opacity-100 z-10 relative" data-slide="0">
                    <div class="w-full lg:w-7/12 text-left flex flex-col gap-6" data-aos="fade-up">
                        <h1 class="text-4xl md:text-5xl lg:text-6xl font-syne font-bold leading-tight text-white">
                            Maintenance <span class="bg-gradient-to-r from-yellow-400 to-yellow-700 bg-clip-text text-transparent">Services</span> Solutions
                        </h1>
                        <p class="text-base md:text-lg text-gray-300 font-sans leading-relaxed">
                            PT Cahaya Lintang Abadi merupakan perusahaan yang bergerak di bidang penyedia jasa perawatan jalan tol, pemeliharaan infrastruktur, jasa kebersihan, dan penyediaan tenaga kerja.
                        </p>
                        <div class="flex flex-col sm:flex-row gap-4 mt-2">
                            <a href="#kontak" class="btn-glow bg-yellow-500 text-white px-8 py-4 text-sm font-bold shadow-[0_4px_6px_rgba(234,179,8,0.25)] hover:bg-yellow-400 transition-colors text-center">Hubungi Kami</a>
                            <a href="#layanan" class="border border-gray-400 text-white px-8 py-4 text-sm font-bold hover:bg-white/10 transition-colors text-center">Layanan Kami</a>
                        </div>
                    </div>
                    <div class="w-full lg:w-5/12 flex flex-col items-center justify-center text-center" data-aos="fade-up" data-aos-delay="200">
                        <div class="w-48 h-48 md:w-64 md:h-64 flex items-center justify-center ">
                            <img src="/images/logo-cla.webp" alt="PT Cahaya Lintang Abadi" class="max-w-full max-h-full object-contain" />
                        </div>
                        <div class="mt-6 bg-yellow-500/10 border border-yellow-500/30 px-4 py-2 rounded-full">
                            <h5 class="text-yellow-500 font-mono text-xs uppercase tracking-widest">Toll Road Maintenance Specialist</h5>
                        </div>
                    </div>
                </div>

                <!-- Slide 2 -->
                <div class="hero-slide w-full flex flex-col items-center justify-center text-center gap-8 transition-all duration-700 opacity-0 pointer-events-none z-0 absolute inset-0" data-slide="1">
                    <div class="w-48 h-48 md:w-64 md:h-64 flex items-center justify-center ">
                        <img src="/images/logo-cla.webp" alt="PT Cahaya Lintang Abadi" class="max-w-full max-h-full object-contain" />
                    </div>
                    <div class="max-w-3xl flex flex-col items-center gap-6">
                        <h1 class="text-3xl md:text-5xl lg:text-6xl font-syne font-bold leading-tight text-white uppercase tracking-tight">
                            "Partner in Excellence"
                        </h1>
                        <div class="bg-yellow-500/10 border border-yellow-500/30 px-6 py-2 rounded-full">
                            <h5 class="text-yellow-500 font-mono text-sm uppercase tracking-widest font-bold">#KamiSiapMelayani</h5>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Navigation Buttons -->
            <button id="hero-prev" class="absolute left-0 top-1/2 -translate-y-1/2 -translate-x-4 md:-translate-x-12 z-20 bg-black/50 border border-white/20 text-white hover:bg-yellow-500 hover:text-black hover:border-yellow-500 w-12 h-12 rounded-full flex items-center justify-center transition-all duration-300 cursor-pointer" aria-label="Previous slide">
                <Icon icon="fa-solid fa-chevron-left" class="text-lg" />
            </button>
            <button id="hero-next" class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-4 md:translate-x-12 z-20 bg-black/50 border border-white/20 text-white hover:bg-yellow-500 hover:text-black hover:border-yellow-500 w-12 h-12 rounded-full flex items-center justify-center transition-all duration-300 cursor-pointer" aria-label="Next slide">
                <Icon icon="fa-solid fa-chevron-right" class="text-lg" />
            </button>

            <!-- Pagination Dots -->
            <div class="flex justify-center gap-3 mt-12">
                <button class="hero-dot w-3 h-3 rounded-full bg-yellow-500 transition-all duration-300 cursor-pointer" data-index="0" aria-label="Go to slide 1"></button>
                <button class="hero-dot w-3 h-3 rounded-full bg-white/30 hover:bg-white/50 transition-all duration-300 cursor-pointer" data-index="1" aria-label="Go to slide 2"></button>
            </div>
        </div>
        <!-- Scroll indicator -->
        <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 z-10" data-aos="fade-up" data-aos-delay="600">
            <span class="text-white/30 font-mono text-[10px] tracking-widest uppercase">Scroll</span>
            <div class="w-px h-10 bg-gradient-to-b from-yellow-500/60 to-transparent animate-glow"></div>
        </div>
    </main>

    <!-- Marquee ticker -->
    <div class="w-full overflow-hidden border-y border-white/10 bg-neutral-950 py-3" aria-hidden="true">
        <div class="marquee-track">
            {[
                "TOLL ROAD MAINTENANCE","TRAFFIC CLEANING","ROAD CLEANING","GARDEN MAINTENANCE",
                "DRAINAGE SYSTEM","CONCRETE BARRIER","BRONJONG WORKS","TENAGA KERJA","TRAFFIC SIGN",
                "TOLL ROAD MAINTENANCE","TRAFFIC CLEANING","ROAD CLEANING","GARDEN MAINTENANCE",
                "DRAINAGE SYSTEM","CONCRETE BARRIER","BRONJONG WORKS","TENAGA KERJA","TRAFFIC SIGN"
            ].map(item => (
                <span class="font-mono text-[11px] text-neutral-500 tracking-widest uppercase px-8 shrink-0">
                    <span class="text-yellow-600 mr-3">✦</span>{item}
                </span>
            ))}
        </div>
    </div>

    <hr class="border-t border-white/20" />

    <!-- Tentang Perusahaan Section -->
    <section id="tentang" class="w-full flex justify-center py-16 md:py-24 px-4 md:px-8">
        <div class="max-w-7xl w-full flex flex-col md:flex-row gap-16 items-start">
            <img src="/galeri/personel_1.webp" alt="Tentang PT Cahaya Lintang Abadi" class="w-full md:w-[523px] h-[300px] md:h-[502px] object-cover shadow-[0_25px_50px_rgba(0,0,0,0.25)]" loading="lazy" data-aos="fade-right" />
            <div class="flex-1 flex flex-col gap-6 pt-6" data-aos="fade-left">
                <div class="text-yellow-400 font-mono text-xs px-3 py-1 self-start">
                    #1 // TENTANG PERUSAHAAN
                </div>
                <h2 class="text-3xl md:text-5xl font-bold font-syne leading-tight">
                    Dirancang untuk Ketangguhan
                </h2>
                <p class="text-base text-gray-400 font-sans max-w-2xl leading-relaxed">
                    PT Cahaya Lintang Abadi berkomitmen untuk selalu memberikan layanan yang prima dan sempurna. 
                    Kami telah menjalin kerja sama dengan beberapa BUMN terkemuka yang menjadi mitra bisnis strategis kami. 
                    Pelaksanaan pekerjaan dengan manajemen yang profesional, berintegritas dan penerapan prinsip-prinsip Good Corporate Governance (GCG) akan selalu kami terapkan seiring dalam perjalanan bisnis kami. 
                    #KamiSiapMelayani
                </p>
                <div class="flex flex-col lg:flex-row gap-6 mt-8">
                    <div class="flex-1 border border-white/20 p-5 flex gap-4 bg-white/5">
                        <div class="text-yellow-500 font-mono text-xs mt-1">01.</div>
                        <div>
                            <h4 class="font-bold text-sm mb-1 font-sans text-white">
                                Keunggulan Operasional
                            </h4>
                            <p class="text-gray-400 text-xs font-light font-sans">
                                Konsistensi ketat terhadap target waktu penyelesaian proyek
                                infrastruktur.
                            </p>
                        </div>
                    </div>
                    <div class="flex-1 border border-white/20 p-5 flex gap-4 bg-white/5">
                        <div class="text-yellow-500 font-mono text-xs mt-1">02.</div>
                        <div>
                            <h4 class="font-bold text-sm mb-1 font-sans text-white">
                                Tim Profesional
                            </h4>
                            <p class="text-gray-400 text-xs font-light font-sans">
                                Profil kompetensi tenaga kerja tinggi tersertifikasi di
                                lapangan ekstrim.
                            </p>
                        </div>
                    </div>
                </div>
                <div class="grid grid-cols-3 gap-6 mt-8 pt-8 border-t border-white/10 w-full">
                    <div>
                        <div class="text-3xl md:text-4xl font-bold font-syne text-yellow-500" id="counter-layanan">0+</div>
                        <div class="text-[10px] md:text-xs text-gray-400 font-sans uppercase tracking-wider mt-1">Layanan Utama</div>
                    </div>
                    <div>
                        <div class="text-3xl md:text-4xl font-bold font-syne text-yellow-500" id="counter-pengalaman">0+</div>
                        <div class="text-[10px] md:text-xs text-gray-400 font-sans uppercase tracking-wider mt-1">Tahun Pengalaman</div>
                    </div>
                    <div>
                        <div class="text-3xl md:text-4xl font-bold font-syne text-yellow-500" id="counter-proyek">0+</div>
                        <div class="text-[10px] md:text-xs text-gray-400 font-sans uppercase tracking-wider mt-1">Proyek Strategis</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Haluan Utama Section -->
    <section id="visi-misi" class="w-full bg-neutral-900 border-y border-white/20 py-16 md:py-32 px-4 md:px-8 flex justify-center">
        <div class="max-w-7xl w-full flex flex-col items-center">
            <div class="text-yellow-400 font-mono text-xs px-3 py-1 self-center" data-aos="fade-up">
                #2 // HALUAN UTAMA
            </div>
            <h2 class="text-3xl md:text-5xl font-bold font-syne mt-4 mb-16 text-center" data-aos="fade-up" data-aos-delay="100">
                Visi & Misi Perusahaan
            </h2>
            <div class="flex flex-col md:flex-row w-full gap-0">
                <div class="flex-1 bg-neutral-900 border border-white/20 p-8 md:p-12" data-aos="fade-right">
                    <div class="flex items-center gap-4 mb-6">
                        <div class="w-12 h-12 border border-yellow-500 text-yellow-500 bg-yellow-500/10 flex items-center justify-center">
                            <Icon icon="fa-solid fa-eye" class="fa-lg" />
                        </div>
                        <h3 class="text-2xl font-bold font-syne text-white">Visi Kami</h3>
                    </div>
                    <p class="text-gray-400 text-base font-light font-sans leading-relaxed">
                        Menjadi perusahaan penyedia jasa konstruksi, pemeliharaan jalan
                        tol, dan penyedia tenaga kerja nasional utama yang diakui atas
                        keunggulan kualitas operasional, integritas, serta efisiensi
                        anggaran di setiap lini proyek.
                    </p>
                </div>

                <div class="flex-1 border border-white/20 border-t-0 md:border-t md:border-l-0 p-8 md:p-12" data-aos="fade-left">
                    <div class="flex items-center gap-4 mb-6">
                        <div class="w-12 h-12 border border-yellow-500 text-yellow-500 bg-yellow-500/10 flex items-center justify-center">
                            <Icon icon="fa-solid fa-bullseye" class="fa-lg" />
                        </div>
                        <h3 class="text-2xl font-bold font-syne text-white">Misi Kami</h3>
                    </div>
                    <ul class="text-gray-400 text-base font-light font-sans space-y-4">
                        <li class="flex gap-3">
                            <span class="font-mono text-yellow-500">01.</span>
                            <span>Menyelenggarakan tata kelola pemeliharaan jalan tol dan infrastruktur dengan standar regulasi keselamatan terbaik.</span>
                        </li>
                        <li class="flex gap-3">
                            <span class="font-mono text-yellow-500">02.</span>
                            <span>Menyediakan pengelolaan sumber daya manusia (workforce supply) yang terampil, tangguh, dan bersertifikasi industri.</span>
                        </li>
                        <li class="flex gap-3">
                            <span class="font-mono text-yellow-500">03.</span>
                            <span>Membangun kemitraan strategis jangka panjang bersama entitas BUMN dan Swasta berlandaskan azas keterbukaan dan kepuasan pelanggan.</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- Matriks Kapabilitas / Layanan Infrastruktur Section -->
    <section id="layanan" class="w-full flex justify-center py-16 md:py-32 px-4 md:px-8">
        <div class="max-w-7xl w-full flex flex-col">
            <div class="flex flex-col md:flex-row justify-between items-end gap-8 mb-16">
                <div data-aos="fade-right">
                    <div class="text-yellow-400 font-mono text-xs px-3 py-1 inline-block mb-3">
                        #3 // MATRIKS Kapabilitas
                    </div>
                    <h2 class="text-3xl md:text-5xl font-bold font-syne">Layanan Infrastruktur</h2>
                    <span class="section-line" data-aos="fade-right" data-aos-delay="200"></span>
                </div>
                <div class="border-l border-yellow-700 pl-4 max-w-sm" data-aos="fade-left">
                    <p class="text-gray-400 text-xs font-light font-sans leading-relaxed">
                        Sembilan pilar utama layanan konstruksi dan pemeliharaan koridor
                        transit yang dioperasikan secara presisi dan sistematis.
                    </p>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-0">
                <ServiceCard title="Toll Road Maintenance"
                    description="Perbaikan struktural rutin, pemeliharaan perkerasan jalan tol, dan patching aspal pada jalur koridor utama logistik lintas provinsi."
                    points={[
                        "Patching aspal & perbaikan lubang (pothole)",
                        "Pemeliharaan perkerasan jalan (scrapping, filling, overlay)",
                        "Perbaikan struktural jembatan & jalan tol"
                    ]}
                    src="/galeri/kompresor.webp" data-aos="fade-up" data-aos-delay="0" />
                <ServiceCard title="Traffic Cleaning Service"
                    description="Pekerjaan mekanis rehabilitasi, pemasangan, dan penyelarasan struktur sambungan siar muai pada jembatan dan jalan layang."
                    points={[
                        "Pembersihan & perawatan expansion joint (siar muai)",
                        "Pembersihan guardrail & pagar pengaman jalan",
                        "Pembersihan rambu & marka jalan secara mekanis"
                    ]}
                    src="/images/traffic-cleaning-service.webp" data-aos="fade-up" data-aos-delay="100" />
                <ServiceCard title="Traffic Sign Cleaning"
                    description="Pembersihan berkala rambu lalu lintas, reflektor pembatas jalan, untuk menjamin visibilitas aman bagi pengendara."
                    points={[
                        "Pembersihan rambu petunjuk arah & rambu peringatan",
                        "Perawatan reflektor pembatas jalan (delineator)",
                        "Inspeksi visibilitas rambu malam hari"
                    ]}
                    src="/galeri/personel_11.webp" data-aos="fade-up" data-aos-delay="200" />
                <ServiceCard title="Road Cleaning"
                    description="Pembersihan area perkerasan jalan tol dari sisa puing, debu makadam, vegetasi liar merayap demi kelancaran laju kendaraan."
                    points={[
                        "Penyapuan jalan mekanis (sweeper truck) & manual",
                        "Pembersihan ceceran material/puing di lajur tol",
                        "Penanganan tumpahan oli/zat kimia berbahaya"
                    ]}
                    src="/images/street-sweeping-1.webp" data-aos="fade-up" data-aos-delay="0" />
                <ServiceCard title="Garden Maintenance"
                    description="Penataan arsitektur lanskap hijau, perawatan tanaman media jalan, pemotongan kurap di sepanjang koridor rumija jalan tol."
                    points={[
                        "Pemotongan rumput rumija (ruang milik jalan)",
                        "Perawatan tanaman hias di median jalan tol",
                        "Pemangkasan pohon yang menghalangi pandangan/rambu"
                    ]}
                    src="/images/garden-maintenance.webp" data-aos="fade-up" data-aos-delay="100" />
                <ServiceCard title="Drainage System Cleaning"
                    description="Normalisasi, pembersihan sedimen lumpur, dan pembersihan sampah pada saluran air semen (u-ditch) penunjang badan jalan."
                    points={[
                        "Pengerukan sedimen lumpur pada saluran u-ditch",
                        "Pembersihan sampah penyumbat gorong-gorong",
                        "Pemeliharaan & perbaikan dinding saluran air"
                    ]}
                    src="/images/drainage-system-cleaning.webp" data-aos="fade-up" data-aos-delay="200" />
                <ServiceCard title="Concrete Barrier Cleaning"
                    description="Pembersihan mekanis beton pembatas jalur (movable concrete barrier) guna menjaga visibilitas marka regulasi tetap bersih."
                    points={[
                        "Pencucian beton pembatas jalan (MCB) berkala",
                        "Pengecatan ulang marka pembatas jalan",
                        "Pembersihan reflektor pada barrier beton"
                    ]}
                    src="/images/concrete-barrier.webp" data-aos="fade-up" data-aos-delay="0" />
                <ServiceCard title="Bronjong Works"
                    description="Pemasangan anyaman kawat baja berlapis seng dengan isi batu (gabion) untuk penahan tebing rawan longsor di tepi jalur arteri."
                    points={[
                        "Perakitan & pemasangan kawat bronjong (gabion)",
                        "Pengisian batu kali berkualitas tinggi",
                        "Proteksi lereng & tebing rawan longsor"
                    ]}
                    src="/images/gabion-works.webp" data-aos="fade-up" data-aos-delay="100" />
                <ServiceCard title="Penyedia Tenaga Kerja"
                    description="Penyediaan dan manajemen terintegrasi tim operasional lapangan tangguh bersertifikasi khusus untuk industri konstruksi berat."
                    points={[
                        "Penyediaan tenaga kerja lapangan (flagman, sweeper, gardener)",
                        "Pelatihan keselamatan kerja (K3) konstruksi jalan tol",
                        "Manajemen & pengawasan operasional terintegrasi"
                    ]}
                    src="/images/labor-supply.webp" data-aos="fade-up" data-aos-delay="200" />
            </div>
        </div>
